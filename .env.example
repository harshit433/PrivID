# Database
DATABASE_URL=postgresql://privid:privid_dev@localhost:5432/privid

# Redis
REDIS_URL=redis://localhost:6379

# JWT — generate with: node -e "require('crypto').generateKeyPairSync('rsa',{modulusLength:2048,publicKeyEncoding:{type:'spki',format:'pem'},privateKeyEncoding:{type:'pkcs8',format:'pem'}})"
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRES_IN=24h

# App
NODE_ENV=development
API_PORT=3000
BUSINESS_API_PORT=3002

# Admin console (admin-dashboard) — x-admin-key header
ADMIN_API_KEY=change-me-to-a-long-random-secret
SIGNALING_PORT=3001
API_BASE_URL=http://localhost:3000

# Passive liveness (onboarding) — Luxand.cloud. Free token at https://luxand.cloud
# The client captures one selfie; the server forwards it for a real/spoof check.
# LUXAND_API_TOKEN=
# Pass threshold: accepts 0–1 (0.5) or 0–100 (50). Lower = more lenient.
# LIVENESS_CONFIDENCE_THRESHOLD=0.5

# Docker API image platform (Apple Silicon + arm64 SDK default)
# DOCKER_PLATFORM=linux/arm64
# DOCKER_PLATFORM=linux/amd64

# Setu / DigiLocker — defer until govt ID
# SETU_CLIENT_ID=
# SETU_CLIENT_SECRET=

# Cloudflare TURN — defer until real calls
# TURN_URL=
# TURN_USERNAME=
# TURN_CREDENTIAL=

# Stream Chat — messaging (key is public, secret is server-only)
# Dashboard → your app → App Access Keys
STREAM_API_KEY=
STREAM_API_SECRET=
# After deploy, set the "Before Message Send" webhook in the Stream dashboard to:
#   <API_BASE_URL>/chat/webhook

# ── DigiLocker KYC via Setu (real government identity verification) ──────────────
# Get these from your Setu dashboard (https://docs.setu.co/data/digilocker).
# The sandbox works out of the box; leave unset to disable govt-ID verification
# (the app shows a clean "briefly unavailable" message, never a mock success).
SETU_DG_BASE_URL=https://dg-sandbox.setu.co   # prod: https://dg.setu.co
SETU_DG_CLIENT_ID=
SETU_DG_CLIENT_SECRET=
SETU_DG_PRODUCT_INSTANCE_ID=
# Where DigiLocker returns the user after consent (a page you host; the app also
# polls status, so any valid https URL works, e.g. https://trustroute.live/kyc/done)
SETU_DG_REDIRECT_URL=

# Masked calling & payments (Phase 3)
TELEPHONY_PROVIDER=mock
# TELEPHONY_WEBHOOK_SECRET=change-me
# EXOTEL_SID=
# EXOTEL_API_KEY=
# EXOTEL_TOKEN=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAYX_ACCOUNT_NUMBER=
RAZORPAYX_WEBHOOK_SECRET=
RAZORPAYX_MOCK=true

# ── Phone OTP (optional add-phone) via MSG91 widget ─────────────────────────────
# Account authkey (server-side verify of the widget access token). The widget ID +
# token/auth live in the mobile app (src/config/msg91.config.ts).
MSG91_AUTH_KEY=
