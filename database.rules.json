{
  "rules": {
    ".read": false,
    ".write": false,

    "calls": {
      "$callId": {
        ".read": "auth != null && (data.child('caller_id').val() === auth.uid || data.child('callee_id').val() === auth.uid)",
        ".write": false
      }
    },

    "status": {
      "$userId": {
        ".read": "auth != null",
        ".write": false
      }
    },

    "activities": {
      "$activityId": {
        ".read": "auth != null && data.child('participants').child(auth.uid).exists()",
        ".write": false,
        "messages": {
          ".read": "auth != null && root.child('activities').child($activityId).child('participants').child(auth.uid).exists()"
        }
      }
    }
  }
}
