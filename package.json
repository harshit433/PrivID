{
  "name": "trustroute-backend-v2",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=@trustroute/core && npm run build --workspace=@trustroute/api && npm run build --workspace=@trustroute/worker",
    "dev": "concurrently -n core,api,worker -c blue,green,magenta \"npm:dev:core\" \"npm:dev:api\" \"npm:dev:worker\"",
    "dev:core": "npm run dev --workspace=@trustroute/core",
    "dev:api": "npm run dev --workspace=@trustroute/api",
    "dev:worker": "npm run dev --workspace=@trustroute/worker",
    "db:generate": "npm run db:generate --workspace=@trustroute/core",
    "db:migrate": "npm run db:migrate --workspace=@trustroute/core",
    "db:seed": "npm run db:seed --workspace=@trustroute/core",
    "db:reset": "npm run db:reset --workspace=@trustroute/core",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
