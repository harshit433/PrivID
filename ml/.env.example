# TrustRoute ML Service — environment variables
# In Railway: set these in the service → Variables tab

# ── Required ──────────────────────────────────────────────────────────────────
# Same DATABASE_URL as the Node.js service (copy from there)
DATABASE_URL=postgresql://user:password@host:5432/privid

# Shared secret — Node.js backend sends this as X-API-Key on every request
# Set the same value in Node.js env as ML_API_KEY
ML_API_KEY=change-me-to-a-strong-secret

# ── Railway Volume ─────────────────────────────────────────────────────────────
# In Railway: add a Volume → mount path /data/models
# This persists trained model files across deploys.
MODEL_DIR=/data/models

# ── Training ──────────────────────────────────────────────────────────────────
# URL of the deployed Node.js backend (for generate_dataset)
SIM_API_URL=https://hospitable-passion-production-fb2f.up.railway.app
SIM_API_KEY=privid-sim-2024

# Separate key to protect POST /admin/train (defaults to ML_API_KEY if unset)
TRAIN_API_KEY=change-me-to-a-strong-secret

# ── Optional ──────────────────────────────────────────────────────────────────
# PORT is set automatically by Railway — do not override
# PORT=8001
