# ── Core (required) ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/trustroute
REDIS_URL=redis://localhost:6379

# ── Auth / JWT (RS256) ───────────────────────────────────────────────────────
# Provide either the *_B64 vars (base64 of the PEM) or point *_PATH at PEM files.
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
# JWT_PUBLIC_KEY_B64=
# JWT_PRIVATE_KEY_B64=
ADMIN_API_KEY=

# ── Feature toggles (dev) ────────────────────────────────────────────────────
ENABLE_SIMULATION=false
MOCK_KYC=true
MOCK_LIVENESS=true
TELEPHONY_PROVIDER=mock

# ── Providers (leave blank in dev to use mocks) ──────────────────────────────
STREAM_API_KEY=
STREAM_API_SECRET=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_DATABASE_URL=
SETU_DG_BASE_URL=
SETU_DG_CLIENT_ID=
SETU_DG_CLIENT_SECRET=
SETU_DG_PRODUCT_INSTANCE_ID=
SETU_DG_REDIRECT_URL=
LIVENESS_API_KEY=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SID=
EXOTEL_SUBDOMAIN=
EXOTEL_CALLER_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAYX_ACCOUNT_NUMBER=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_BASE_URL=
MSG91_AUTH_KEY=
