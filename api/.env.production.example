# ─── Database ──────────────────────────────────────────────────────────────────
# Set this in docker-compose.prod.yml env via POSTGRES_PASSWORD
DATABASE_URL=postgresql://privid:CHANGE_ME@postgres:5432/privid

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@redis:6379
# Railway: reference Redis service private URL (preferred over public REDIS_URL)
# REDIS_PRIVATE_URL=${{Redis.REDIS_PRIVATE_URL}}

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate keys:
#   mkdir -p api/keys
#   openssl genrsa -out api/keys/private.pem 2048
#   openssl rsa -in api/keys/private.pem -pubout -out api/keys/public.pem
JWT_PRIVATE_KEY_PATH=/app/api/keys/private.pem
JWT_PUBLIC_KEY_PATH=/app/api/keys/public.pem
JWT_ACCESS_EXPIRES_IN=24h

# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=3000
API_BASE_URL=https://api.yourdomain.com

# ─── Business Suite API (companies, API key auth) ───────────────────────────────
BUSINESS_API_PORT=3002
# Public URL for Business Web Dashboard + Scan App (separate deploy)
# BUSINESS_API_BASE_URL=https://business-api.yourdomain.com

# ─── MSG91 (OTP + SIM SMS) ─────────────────────────────────────────────────────
MSG91_AUTH_KEY=your_msg91_authkey
# OTP template ID from MSG91 → OTP section (same template used for login OTP). Required for SIM SMS until Flow template is set up.
MSG91_OTP_TEMPLATE_ID=your_otp_template_id
# Legacy alias — use MSG91_OTP_TEMPLATE_ID instead
MSG91_TEMPLATE_ID=your_otp_template_id
# Optional — MSG91 Flow/Template ID for SIM SMS with app-hash (Android auto-read). Create in MSG91 → Templates.
# DLT example: "<#> PrivID SIM code is ##VAR1##. ##VAR2##"  (VAR1=code, VAR2=app hash)
MSG91_SIM_SMS_FLOW_ID=
MSG91_SIM_SMS_VAR_CODE=VAR1
MSG91_SIM_SMS_VAR_HASH=VAR2
MSG91_SMS_SENDER=PRIVID
MSG91_WIDGET_ID=your_widget_id

# ─── LiveKit ───────────────────────────────────────────────────────────────────
LIVEKIT_URL=wss://privid-0l647dh5.livekit.cloud
LIVEKIT_API_KEY=APIR3htFEWeqfEw
LIVEKIT_API_SECRET=JEBM8iSojzlIFb51ypoRf7EEvO0ayb7cCS2uRmWiCVV

# ─── Stream Chat (messaging) ───────────────────────────────────────────────────
# Dashboard → your app → App Access Keys. Then set the "Before Message Send"
# webhook URL to <API_BASE_URL>/chat/webhook for server-side enforcement.
STREAM_API_KEY=your_stream_key
STREAM_API_SECRET=your_stream_secret

# ─── AWS S3 (avatar storage) ───────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=privid-avatars
# Optional separate bucket for 24h status media (falls back to AWS_S3_BUCKET)
AWS_S3_STATUS_BUCKET=trustroute-status

# ─── Passive liveness (onboarding) — Luxand.cloud ─────────────────────────────
# The client captures one selfie; the server forwards it to Luxand for a
# real/spoof check. Free token at https://luxand.cloud.
LUXAND_API_TOKEN=your_luxand_token
# Pass threshold: accepts 0–1 (0.5) or 0–100 (50). Lower = more lenient.
LIVENESS_CONFIDENCE_THRESHOLD=0.5

# ─── 3DiVi liveness (legacy / optional) ───────────────────────────────────────
# THREEDIVI_SDK_PATH=/opt/threedivi-sdk
# THREEDIVI_NODE_API_PATH=/opt/threedivi-sdk/node_js_api
# THREEDIVI_RUNNER=python

# ─── Google Play Integrity (Android device attestation) ────────────────────────
# Service account JSON with Play Integrity API access, linked in Play Console.
# Falls back to FIREBASE_SERVICE_ACCOUNT_JSON if unset (same GCP project).
# GOOGLE_PLAY_INTEGRITY_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# ANDROID_PACKAGE_NAME=com.prividapp
# PLAY_INTEGRITY_STRICT=true
# PLAY_INTEGRITY_ALLOW_SIDELOAD=false
# Only pin during a single-build rollout; remove once Play Integrity recognizes the version.
# ANDROID_EXPECTED_VERSION_CODE=31
# See docs/PLAY_INTEGRITY_PRODUCTION.md
# DigiLocker via Setu (sandbox: dg-sandbox.setu.co · prod: dg.setu.co)
# SETU_DG_BASE_URL=https://dg-sandbox.setu.co
# SETU_DG_CLIENT_ID=your_client_id
# SETU_DG_CLIENT_SECRET=your_client_secret
# SETU_DG_PRODUCT_INSTANCE_ID=your_product_instance_id
# Must match the redirect URL registered in Setu Bridge (public HTTPS).
# SETU_DG_REDIRECT_URL=https://www.trustroute.live/digilocker/
