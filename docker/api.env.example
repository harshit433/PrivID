# Copy to backend/.env or merge into api/.env — docker-compose overrides DATABASE_URL / REDIS_URL.

NODE_ENV=development
API_PORT=3000
API_BASE_URL=http://localhost:3000

# Docker Compose sets these for the api service (do not use localhost inside the container):
# DATABASE_URL=postgresql://privid:privid_dev@postgres:5432/privid
# REDIS_URL=redis://redis:6379

JWT_PRIVATE_KEY_PATH=/app/api/keys/private.pem
JWT_PUBLIC_KEY_PATH=/app/api/keys/public.pem
JWT_ACCESS_EXPIRES_IN=24h

MSG91_AUTH_KEY=

THREEDIVI_SDK_PATH=/opt/threedivi-sdk
THREEDIVI_NODE_API_PATH=/opt/threedivi-node-api
THREEDIVI_LIVENESS_MODIFICATION=2d_light
THREEDIVI_LIVENESS_MIN_CONFIDENCE=0.5

# Apple Silicon + arm64 SDK (default). For x86-64 SDK only: linux/amd64
# DOCKER_PLATFORM=linux/arm64

EXPRESS_JSON_LIMIT=15mb
