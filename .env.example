# Database
DATABASE_URL=postgresql://privid:privid_dev@localhost:5432/privid

# Redis
REDIS_URL=redis://localhost:6379

# JWT — generate with: node -e "require('crypto').generateKeyPairSync('rsa',{modulusLength:2048,publicKeyEncoding:{type:'spki',format:'pem'},privateKeyEncoding:{type:'pkcs8',format:'pem'}})"
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRES_IN=24h

# App
NODE_ENV=development
API_PORT=3000
BUSINESS_API_PORT=3002

# Admin console (admin-dashboard) — x-admin-key header
ADMIN_API_KEY=change-me-to-a-long-random-secret
SIGNALING_PORT=3001
API_BASE_URL=http://localhost:3000

# MSG91 OTP Widget — server-side Authkey (verify access-token after client verifyOTP)
# Dashboard → OTP → Server-side integration → Get Authkey
MSG91_AUTH_KEY=

# Passive liveness (onboarding) — Luxand.cloud. Free token at https://luxand.cloud
# The client captures one selfie; the server forwards it for a real/spoof check.
# LUXAND_API_TOKEN=
# Pass threshold: accepts 0–1 (0.5) or 0–100 (50). Lower = more lenient.
# LIVENESS_CONFIDENCE_THRESHOLD=0.5

# 3DiVi Face SDK liveness (legacy — download from 3divi.com, license required)
# Root folder containing lib/, conf/facerec/, license/
# THREEDIVI_SDK_PATH=/path/to/face-sdk
# Optional: path to node_js_api from https://github.com/3DiVi/face-sdk (defaults to sibling of SDK)
# THREEDIVI_NODE_API_PATH=/path/to/node_js_api
# Liveness model: 2d_light | 2d_hard | 3d (see 3DiVi docs)
# THREEDIVI_LIVENESS_MODIFICATION=2d_light
# THREEDIVI_LIVENESS_MIN_CONFIDENCE=0.5

# Docker API image platform (Apple Silicon + arm64 SDK default)
# DOCKER_PLATFORM=linux/arm64
# DOCKER_PLATFORM=linux/amd64

# Setu / DigiLocker — defer until govt ID
# SETU_CLIENT_ID=
# SETU_CLIENT_SECRET=

# Cloudflare TURN — defer until real calls
# TURN_URL=
# TURN_USERNAME=
# TURN_CREDENTIAL=

# Stream Chat — messaging (key is public, secret is server-only)
# Dashboard → your app → App Access Keys
STREAM_API_KEY=
STREAM_API_SECRET=
# After deploy, set the "Before Message Send" webhook in the Stream dashboard to:
#   <API_BASE_URL>/chat/webhook
