# ── Core (required) ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/trustroute
REDIS_URL=redis://localhost:6379
API_BASE_URL=https://api-production-a71f.up.railway.app

# ── Auth / JWT (RS256) ───────────────────────────────────────────────────────
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
# JWT_PUBLIC_KEY_B64=
# JWT_PRIVATE_KEY_B64=
ADMIN_API_KEY=

# ── Feature toggles ──────────────────────────────────────────────────────────
# In production on Railway, leave MOCK_* false and set real provider credentials.
ENABLE_SIMULATION=false
MOCK_KYC=false
MOCK_LIVENESS=false
TELEPHONY_PROVIDER=exotel

# ── Stream (chat + video) ────────────────────────────────────────────────────
STREAM_API_KEY=
STREAM_API_SECRET=

# ── Firebase (FCM + RTDB call signaling) ─────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_DATABASE_URL=

# ── DigiLocker via Setu ──────────────────────────────────────────────────────
# Railway runs outside India — route through Mumbai proxy when geo-blocked.
SETU_DG_BASE_URL=https://dg-sandbox.setu.co
SETU_DG_CLIENT_ID=
SETU_DG_CLIENT_SECRET=
SETU_DG_PRODUCT_INSTANCE_ID=
SETU_DG_REDIRECT_URL=https://api-production-a71f.up.railway.app/onboarding/digilocker/return
SETU_DG_PROXY_BASE_URL=
SETU_DG_PROXY_SECRET=

# ── Liveness / face match (Luxand) ───────────────────────────────────────────
LUXAND_API_TOKEN=
# LIVENESS_API_KEY=   # alias for LUXAND_API_TOKEN
# LIVENESS_BASE_URL=https://api.luxand.cloud/photo/liveness
LIVENESS_CONFIDENCE_THRESHOLD=0.5
FACE_MATCH_THRESHOLD=0.7

# ── Masked calling (Exotel) ──────────────────────────────────────────────────
EXOTEL_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
TELEPHONY_WEBHOOK_SECRET=

# ── Payments (Razorpay + RazorpayX) ──────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAYX_ACCOUNT_NUMBER=
RAZORPAYX_WEBHOOK_SECRET=

# ── Object storage (S3) ──────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_BASE_URL=

# ── SMS (optional) ───────────────────────────────────────────────────────────
MSG91_AUTH_KEY=

# ── ML behavioural scoring (optional) ────────────────────────────────────────
ML_SERVICE_URL=
ML_API_KEY=
