# PrivID ML Service — environment variables
# Copy to .env and fill in values

# PostgreSQL connection (same as backend/api)
DATABASE_URL=postgresql://user:password@host:5432/privid

# Shared secret checked on every request (must match ML_API_KEY in Node.js env)
ML_API_KEY=privid-ml-dev-key

# Path to trained model .pkl / .onnx files
MODEL_DIR=./models

# Listen port (Railway overrides this automatically)
PORT=8001

# Railway simulation API (used by generate_dataset.py)
SIM_API_URL=https://hospitable-passion-production-fb2f.up.railway.app
SIM_API_KEY=privid-sim-2024
