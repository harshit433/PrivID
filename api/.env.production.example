# ─── Database ──────────────────────────────────────────────────────────────────
# Set this in docker-compose.prod.yml env via POSTGRES_PASSWORD
DATABASE_URL=postgresql://privid:CHANGE_ME@postgres:5432/privid

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@redis:6379

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate keys:
#   mkdir -p api/keys
#   openssl genrsa -out api/keys/private.pem 2048
#   openssl rsa -in api/keys/private.pem -pubout -out api/keys/public.pem
JWT_PRIVATE_KEY_PATH=/app/api/keys/private.pem
JWT_PUBLIC_KEY_PATH=/app/api/keys/public.pem
JWT_ACCESS_EXPIRES_IN=24h

# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=3000
API_BASE_URL=https://api.yourdomain.com

# ─── MSG91 (OTP) ───────────────────────────────────────────────────────────────
MSG91_AUTH_KEY=your_msg91_authkey
MSG91_TEMPLATE_ID=your_otp_template_id
MSG91_WIDGET_ID=your_widget_id

# ─── LiveKit ───────────────────────────────────────────────────────────────────
LIVEKIT_URL=wss://privid-0l647dh5.livekit.cloud
LIVEKIT_API_KEY=APIR3htFEWeqfEw
LIVEKIT_API_SECRET=JEBM8iSojzlIFb51ypoRf7EEvO0ayb7cCS2uRmWiCVV

# ─── AWS S3 (avatar storage) ───────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=privid-avatars

# ─── 3DiVi liveness (optional) ────────────────────────────────────────────────
# THREEDIVI_SDK_PATH=/opt/threedivi-sdk
# THREEDIVI_NODE_API_PATH=/opt/threedivi-sdk/node_js_api
# THREEDIVI_RUNNER=python

# ─── Setu DigiLocker (optional) ───────────────────────────────────────────────
# SETU_CLIENT_ID=your_client_id
# SETU_CLIENT_SECRET=your_client_secret
# SETU_REDIRECT_URL=https://api.yourdomain.com/auth/digilocker/callback
